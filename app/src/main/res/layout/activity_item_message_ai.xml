<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="6dp">

    <LinearLayout
        android:id="@+id/aiBubbleContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:maxWidth="280dp"
        android:background="@drawable/bg_bubble_ai"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/tvAiMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI response text goes here..."
            android:textColor="#111111"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvAiTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/aiBubbleContainer"
        android:layout_alignParentStart="true"
        android:layout_marginTop="3dp"
        android:text="09:41 AM"
        android:textColor="#888888"
        android:textSize="11sp" />
</RelativeLayout>