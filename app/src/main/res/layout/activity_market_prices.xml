<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFC"
    tools:context=".MarketPricesActivity">

    <!-- 1. Top Navigation Toolbar Bar -->
    <RelativeLayout
        android:id="@+id/marketToolbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBackMarket"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#2E7D32" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Daily Market Prices"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- 2. Main Pricing Dashboard Content Scroll Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/marketToolbar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 🟢 The Exact Premium Widget Card Component from your Screenshot -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_weather_card"
                android:backgroundTint="#FFFFFF"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header block area -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ivMarketIcon"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_weather_card"
                        android:backgroundTint="#E8F5E9"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="#2E7D32" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivMarketIcon"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Market Prices"
                            android:textColor="#222222"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Check daily prices for your produce"
                            android:textColor="#666666"
                            android:textSize="13sp" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- Divider Rule Line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0"
                    android:layout_marginBottom="12dp" />

                <!-- Row 1: Maize Commodity Item View -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/tvCrop1Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌽  Maize"
                        android:textColor="#111111"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCrop1Price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="KSh 2,100 / 90kg"
                        android:textColor="#2E7D32"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Row 2: Beans Commodity Item View -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/tvCrop2Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🫘  Beans"
                        android:textColor="#111111"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCrop2Price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="KSh 4,200 / 90kg"
                        android:textColor="#2E7D32"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Row 3: Tomatoes Commodity Item View -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/tvCrop3Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍅  Tomatoes"
                        android:textColor="#111111"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCrop3Price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="KSh 1,500 / crate"
                        android:textColor="#2E7D32"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>